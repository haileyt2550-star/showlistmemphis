generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

model Venue {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  address   String
  city      String
  state     String
  zip       String?
  lat       Float
  lng       Float
  capacity  Int?
  website   String?
  imageUrl  String?
  scrapeUrl String?
  isActive  Boolean  @default(true)
  events    Event[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Event {
  id          String    @id @default(cuid())
  title       String
  artist      String?
  venueId     String
  venue       Venue     @relation(fields: [venueId], references: [id])
  date        DateTime
  doorsTime   DateTime?
  showTime    DateTime?
  ticketUrl   String?
  price       String?
  genre       String?
  imageUrl    String?
  description String?
  source      String
  sourceId    String?
  isPopUp     Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([sourceId, source])
}

model EmailSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  genres    String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}
